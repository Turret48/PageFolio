# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=  # Project Settings → Database → Connection string (URI, Session Pooler)

# Anthropic — IMPORTANT: use PAGEFOLIO_AI_KEY, not ANTHROPIC_API_KEY.
# Claude Code injects an empty ANTHROPIC_API_KEY that overrides .env.local.
# Claude Code also injects ANTHROPIC_BASE_URL without /v1 — the code hardcodes the correct baseURL.
PAGEFOLIO_AI_KEY=

# Google Books
GOOGLE_BOOKS_API_KEY=

# Resend (email)
RESEND_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
